<?xml version="1.0"?>
<info xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="https://apps.nextcloud.com/schema/apps/info.xsd">
	<id>user_group_admin</id>
	<name>Groups</name>
	<summary>User-managed groups with storage grants and external collaborator invitations</summary>
	<description>Lets users create and manage their own groups, invite external collaborators by email, and delegate storage to group members from their own quota.</description>
	<version>1.0.3</version>
	<licence>agpl</licence>
	<author mail="fror@dtu.dk">Frederik Orellana, DTU</author>
	<namespace>UserGroupAdmin</namespace>
	<bootstrap>OCA\UserGroupAdmin\AppInfo\Application</bootstrap>
	<category>organization</category>
	<dependencies>
		<nextcloud min-version="28" max-version="35"/>
		<php min-version="8.2"/>
	</dependencies>
	<remote>
		<groupadmin>appinfo/remote.php</groupadmin>
		<user_group_admin>appinfo/grants.php</user_group_admin>
	</remote>
	<navigations>
		<navigation>
			<name>Groups</name>
			<route>user_group_admin.page.index</route>
			<icon>nav-icon.svg</icon>
			<order>5</order>
		</navigation>
	</navigations>
	<settings>
		<admin>OCA\UserGroupAdmin\Settings\AdminSettings</admin>
	</settings>
</info>
